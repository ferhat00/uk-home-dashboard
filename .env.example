# UK Home Dashboard — Environment Variables
# Copy this file to .env and fill in your API keys

# EPC Register API (https://epc.opendatacommunities.org/)
# Register for free, then generate a Base64-encoded API token
EPC_API_KEY=
EPC_API_EMAIL=

# TfL Unified API (https://api.tfl.gov.uk/)
# Register for free at https://api-portal.tfl.gov.uk/signup
TFL_APP_ID=
TFL_APP_KEY=

# Flask
SECRET_KEY=change-this-to-a-random-string
FLASK_DEBUG=1
